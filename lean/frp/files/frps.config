config init
	option stdout 1
	option stderr 1
	option user frps
	option group frps
	option respawn 1
#	For full configuration options, see:
#	https://github.com/fatedier/frp/blob/master/conf/legacy/frps_legacy_full.ini

config conf 'common'
	option enabled 0
	option bind_port 7000
	option dashboard_addr 0.0.0.0
	option dashboard_port 7500
	option log_file /var/log/frps.log
#	List options with name="_" will be directly appended to config file
#	list _ '# Key-A=Value-A'
